          "id": "https://w3id.org/iqb/v40/a1/x4u",
          "notation": [
            "1.1"
          ],
          "prefLabel": {
            "de": "Fachwissen"
          },
          "definition": {
            "de": "Kenntnisse und Konzepte zielgerichtet wiedergeben"
          }
        },
        {
