            "de": "bekannte Informationen in verschiedenen fachlich relevanten Darstellungsformen erfassen und wiedergeben"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/a4d",
          "notation": [
            "1.4"
          ],
          "prefLabel": {
            "de": "Bewertung"
