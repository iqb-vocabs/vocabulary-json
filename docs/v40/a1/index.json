            "de": "Fachwissen"
          },
          "definition": {
            "de": "komplexere Fragestellungen auf der Grundlage von Kenntnissen und Konzepten planmäßig und konstruktiv bearbeiten"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/b3t",
          "notation": [
            "3.2"
          ],
          "prefLabel": {
            "de": "Erkenntnisgewinnung"
          },
          "definition": {
            "de": "geeignete Untersuchungsmethoden und Modelle zur Bearbeitung komplexer Sachverhalte begründet auswählen und anpassen"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/d3c",
          "notation": [
            "3.3"
          ],
          "prefLabel": {
            "de": "Kommunikation"
          },
          "definition": {
            "de": "Informationen auswerten, reflektieren und für eigene Argumentationen nutzen"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/r7z",
          "notation": [
            "3.4"
          ],
          "prefLabel": {
            "de": "Bewertung"
          },
          "definition": {
            "de": "Argumente zur Bewertung eines Sachverhaltes aus verschiedenen Perspektiven abwägen und Entscheidungsprozesse reflekstieren"
          }
        }
      ]
    }
  ],
