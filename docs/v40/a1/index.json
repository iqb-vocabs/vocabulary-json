          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/a9z",
          "notation": [
            "2.2"
          ],
          "prefLabel": {
            "de": "Erkenntnisgewinnung"
          },
          "definition": {
            "de": "geeignete Untersuchungsmethoden und Modelle zur Bearbeitung überschaubarer Sachverhalte auswählen und anwenden"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/g7z",
          "notation": [
            "2.3"
          ],
          "prefLabel": {
            "de": "Kommunikation"
          },
          "definition": {
            "de": "Informationen erfassen und in geeigneten Darstellungsformen situations- und adressatengerecht veranschaulichen"
          }
        },
        {
          "id": "https://w3id.org/iqb/v40/a1/g2e",
          "notation": [
            "2.4"
          ],
          "prefLabel": {
            "de": "Bewertung"
          },
          "definition": {
            "de": "geeignete Argumente zur Bewertung eines Sachverhaltes auswählen und nutzen"
          }
        }
      ]
    },
    {
      "id": "https://w3id.org/iqb/v40/a1/t4z",
      "notation": [
        "3"
      ],
      "prefLabel": {
        "de": "Anforderungsbereich III"
      },
      "narrower": [
