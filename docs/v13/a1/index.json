{
  "id": "https://w3id.org/iqb/v13/a1/",
  "type": "ConceptScheme",
  "title": {
    "de": "Bildungsstandards Deutsch Primar 2004 - Anforderungsbereiche"
  },
  "description": {
    "de": "Die folgenden Aufgabenbeispiele zeigen die Bandbreite unterschiedlicher Anforderungen. Zur Einschätzung der in den Aufgabenbeispielen gestellten Anforderungen wird auf drei Anforderungsbereiche zurückgegriffen, die hier exemplarisch anhand von Aufgabenstellungen aus zwei Aufgabenbeispielen zum Lesen und zum Schreiben konkretisiert werden."
  },
  "hasTopConcept": [
    {
      "id": "https://w3id.org/iqb/v13/a1/d7b",
      "notation": [
        "I"
      ],
      "prefLabel": {
        "de": "Wiedergeben"
      },
      "definition": {
        "de": "In diesem Anforderungsbereich geben die Schülerinnen und Schüler bekannte Informationen wieder und wenden grundlegende Verfahren und Routinen an."
      }
    },
    {
      "id": "https://w3id.org/iqb/v13/a1/h6f",
      "notation": [
        "II"
      ],
      "prefLabel": {
        "de": "Zusammenhänge herstellen"
      },
      "definition": {
        "de": "In diesem Anforderungsbereich bearbeiten die Schülerinnen und Schüler vertraute Sachverhalte, indem sie erworbenes Wissen und bekannte Methoden anwenden und miteinander verknüpfen."
      }
    },
    {
      "id": "https://w3id.org/iqb/v13/a1/a5s",
      "notation": [
        "III"
      ],
      "prefLabel": {
        "de": "Reflektieren und beurteilen"
      },
      "definition": {
        "de": "In diesem Anforderungsbereich bearbeiten die Schülerinnen und Schüler für sie neue Problemstellungen, die eigenständige Beurteilungen und eigene Lösungsansätze erfordern."
      }
    }
  ],
