                "de": "Texte mit eigenen Worten wiedergeben,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/s2f",
              "notation": [
                "3.3.6"
              ],
              "prefLabel": {
                "de": "zentrale Aussagen eines Textes erfassen und wiedergeben,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/t3d",
              "notation": [
                "3.3.7"
              ],
              "prefLabel": {
                "de": "Aussagen mit Textstellen belegen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/s2e",
              "notation": [
                "3.3.8"
              ],
              "prefLabel": {
                "de": "eigene Gedanken zu Texten entwickeln, zu Texten Stellung nehmen und mit anderen über Texte sprechen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/t2a",
              "notation": [
                "3.3.9"
              ],
              "prefLabel": {
                "de": "bei der Beschäftigung mit literarischen Texten Sensibilität und Verständnis für Gedanken und Gefühle und zwischenmenschliche Beziehungen zeigen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/h5y",
              "notation": [
                "3.3.10"
              ],
              "prefLabel": {
                "de": "Unterschiede und Gemeinsamkeiten von Texten finden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/f2t",
              "notation": [
                "3.3.11"
              ],
              "prefLabel": {
                "de": "handelnd mit Texten umgehen: z.B. illustrieren, inszenieren, umgestalten, collagieren."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v13/k1/y6b",
          "notation": [
            "3.4"
          ],
          "prefLabel": {
            "de": "Texte präsentieren"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v13/k1/r9d",
              "notation": [
                "3.4.1"
              ],
              "prefLabel": {
                "de": "selbstgewählte Texte zum Vorlesen vorbereiten und sinngestaltend vorlesen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/g6c",
              "notation": [
                "3.4.2"
              ],
              "prefLabel": {
                "de": "Geschichten, Gedichte und Dialoge vortragen, auch auswendig,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/d5z",
              "notation": [
                "3.4.3"
              ],
              "prefLabel": {
                "de": "ein Kinderbuch selbst auswählen und vorstellen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/e3h",
              "notation": [
                "3.4.4"
              ],
              "prefLabel": {
                "de": "verschiedene Medien für Präsentationen nutzen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/t2f",
              "notation": [
                "3.4.5"
              ],
              "prefLabel": {
                "de": "bei Lesungen und Aufführungen mitwirken."
              }
            }
          ]
        }
      ]
    },
    {
      "id": "https://w3id.org/iqb/v13/k1/b6p",
      "notation": [
        "4"
      ],
      "prefLabel": {
        "de": "Sprache und Sprachgebrauch untersuchen"
      },
      "definition": {
        "de": "Anknüpfend an ihre Spracherfahrungen entwickeln die Kinder ihr Sprachgefühl weiter und gehen bewusster mit Sprache um. In altersgemäßen, lebensnahen Sprach- und Kommunikationssituationen erfahren und untersuchen die Kinder die Sprache in ihren Verwendungszusammenhängen und gehen dabei auf die inhaltliche Dimension und die Leistung von Wörtern, Sätzen und Texten ein. Sie sprechen auch über Erfahrungen mit anderen Sprachen. Sie verfügen über ein Grundwissen an grammatischen Strukturen, einen Grundbestand an Begriffen und Verfahren zum Untersuchen von Sprache."
      },
      "narrower": [
        {
          "id": "https://w3id.org/iqb/v13/k1/f5c",
          "notation": [
            "4.1"
          ],
          "prefLabel": {
            "de": "sprachliche Verständigung untersuchen"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v13/k1/z7r",
              "notation": [
                "4.1.1"
              ],
              "prefLabel": {
                "de": "Beziehung zwischen Absicht – sprachlichen Merkmalen – Wirkungen untersuchen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/d9b",
              "notation": [
                "4.1.2"
              ],
              "prefLabel": {
                "de": "Unterschiede von gesprochener und geschriebener Sprache kennen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/u5g",
              "notation": [
                "4.1.3"
              ],
              "prefLabel": {
                "de": "Rollen von Sprecher/Schreiber – Hörer/Leser untersuchen und nutzen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/r2f",
              "notation": [
                "4.1.4"
              ],
              "prefLabel": {
                "de": "über Verstehens- und Verständigungsprobleme sprechen."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v13/k1/u7g",
          "notation": [
            "4.2"
          ],
          "prefLabel": {
            "de": "an Wörtern, Sätzen, Texten arbeiten"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v13/k1/t3f",
              "notation": [
                "4.2.1"
              ],
              "prefLabel": {
                "de": "Wörter strukturieren und Möglichkeiten der Wortbildung kennen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/c2h",
              "notation": [
                "4.2.2"
              ],
              "prefLabel": {
                "de": "Wörter sammeln und ordnen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/r7f",
              "notation": [
                "4.2.3"
              ],
              "prefLabel": {
                "de": "sprachliche Operationen nutzen: umstellen, ersetzen, ergänzen, weglassen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/y6q",
              "notation": [
                "4.2.4"
              ],
              "prefLabel": {
                "de": "die Textproduktion und das Textverständnis durch die Anwendung von sprachlichen Operationen unterstützen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/v7x",
              "notation": [
                "4.2.5"
              ],
              "prefLabel": {
                "de": "mit Sprache experimentell und spielerisch umgehen."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v13/k1/a9r",
          "notation": [
            "4.3"
          ],
          "prefLabel": {
            "de": "Gemeinsamkeiten und Unterschiede von Sprachen entdecken"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v13/k1/p6b",
              "notation": [
                "4.3.1"
              ],
              "prefLabel": {
                "de": "Deutsch – Fremdsprache, Dialekt – Standardsprache; Deutsch – Muttersprachen der Kinder mit Migrationshintergrund; Deutsch – Nachbarsprachen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v13/k1/r6q",
