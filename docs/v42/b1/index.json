    {
      "id": "https://w3id.org/iqb/v42/b1/x5f",
      "notation": [
        "2"
      ],
      "prefLabel": {
        "de": "Die chemische Reaktion"
      },
      "definition": {
        "de": "Chemische Reaktionen spielen in der Chemie eine zentrale Rolle und werden in diesem Basiskonzept in den folgenden Zusammenhängen systematisch betrachtet: Donator-Akzeptor-Prinzipien bei Protonen und Elektronenübergängen; Reaktionsmechanismen in der organischen Chemie."
      },
