            },
            {
              "id": "https://w3id.org/iqb/v30/k1/z3q",
              "notation": [
                "3.3.3"
              ],
              "prefLabel": {
                "de": "zitieren, Quellen angeben,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/y7c",
              "notation": [
                "3.3.4"
              ],
              "prefLabel": {
                "de": "Wesentliches markieren,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/c2h",
              "notation": [
                "3.3.5"
              ],
              "prefLabel": {
                "de": "Stichwörter formulieren,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/r4x",
              "notation": [
                "3.3.6"
              ],
              "prefLabel": {
                "de": "Texte gliedern und Teilüberschriften finden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/q5u",
              "notation": [
                "3.3.7"
              ],
              "prefLabel": {
                "de": "Inhalte mit eigenen Worten zusammenfassend wiedergeben,"
