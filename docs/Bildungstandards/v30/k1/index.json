            {
              "id": "https://w3id.org/iqb/v30/k1/c6t",
              "notation": [
                "3.3.8"
              ],
              "prefLabel": {
                "de": "Arbeitsergebnisse zielgerichtet und sachbezogen präsentieren z.B. mit Folie, Plakat, PC."
              }
            }
