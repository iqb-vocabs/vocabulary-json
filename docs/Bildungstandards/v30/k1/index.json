          "prefLabel": {
            "de": "Texte verstehen und nutzen"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/c9y",
              "notation": [
                "3.1.1"
              ],
              "prefLabel": {
                "de": "Lesetechniken und Strategien zum Leseverstehen kennen und anwenden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/t5y",
              "notation": [
                "3.1.2"
              ],
              "prefLabel": {
                "de": "über grundlegende Lesefertigkeiten verfügen: flüssig, sinnbezogen, überfliegend, selektiv,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/d9x",
              "notation": [
                "3.1.3"
              ],
              "prefLabel": {
                "de": "die eigenen Leseziele kennen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/b4r",
              "notation": [
                "3.1.4"
              ],
              "prefLabel": {
                "de": "Vorwissen und neue Informationen unterscheiden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/r9p",
              "notation": [
                "3.1.5"
              ],
              "prefLabel": {
                "de": "Wortbedeutungen klären,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/s6y",
              "notation": [
                "3.1.6"
              ],
              "prefLabel": {
                "de": "Lesehilfen nutzen: z.B. Textsorte, Aufbau, Überschrift, Illustration, Layout,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/g9d",
              "notation": [
                "3.1.7"
              ],
              "prefLabel": {
                "de": "Verfahren zur Textstrukturierung kennen und nutzen: Inhalte zusammenfassen, Zwischenüberschriften formulieren, wesentliche Textstellen kennzeichnen, Bezüge zwischen Textstellen herstellen, Fragen aus dem Text ableiten und beantworten,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/y5s",
              "notation": [
                "3.1.8"
              ],
              "prefLabel": {
                "de": "Verfahren zur Textaufnahme kennen und nutzen: Aussagen erklären, Stichwörter formulieren, Texte und Textabschnitte zusammenfassen."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v30/k1/u4d",
          "notation": [
            "3.2"
          ],
          "prefLabel": {
            "de": "Texte verstehen und nutzen"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/y2z",
              "notation": [
                "3.2.1"
              ],
              "prefLabel": {
                "de": "Literarische Texte verstehen und nutzen"
              },
              "narrower": [
                {
                  "id": "https://w3id.org/iqb/v30/k1/s7b",
                  "notation": [
                    "3.2.1.1"
                  ],
                  "prefLabel": {
                    "de": "aktuelle und klassische Werke der Jugendliteratur und altersangemessene Texte bedeutender Autorinnen und Autoren kennen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/g2a",
                  "notation": [
                    "3.2.1.2"
                  ],
                  "prefLabel": {
                    "de": "epische, lyrische, dramatische Texte unterscheiden und wesentliche Merkmale kennen, insbesondere epische Kleinformen, Erzählung, Kurzgeschichte, Gedichte,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/r3x",
                  "notation": [
                    "3.2.1.3"
                  ],
                  "prefLabel": {
                    "de": "an einem repräsentativen Beispiel Zusammenhänge zwischen Text, Entstehungszeit und Leben des Autors/der Autorin herstellen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/g4b",
                  "notation": [
                    "3.2.1.4"
                  ],
                  "prefLabel": {
                    "de": "zentrale Aussagen erschließen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/y3v",
                  "notation": [
                    "3.2.1.5"
                  ],
                  "prefLabel": {
                    "de": "wesentliche Elemente eines Textes erfassen: Figuren, Raum- und Zeitdarstellung, Konfliktverlauf,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/x7y",
                  "notation": [
                    "3.2.1.6"
                  ],
                  "prefLabel": {
                    "de": "Handlung und Verhaltensweisen beschreiben und werten,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/u3g",
                  "notation": [
                    "3.2.1.7"
                  ],
                  "prefLabel": {
                    "de": "wesentliche Fachbegriffe zur Erschließung von Literatur kennen und anwenden: Autor, Erzähler, Monolog, Dialog, Reim,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/d4e",
                  "notation": [
                    "3.2.1.8"
                  ],
                  "prefLabel": {
                    "de": "grundlegende Gestaltungsmittel erkennen und ihre Wirkungen einschätzen: z.B. Wortwahl, Wiederholung, sprachliche Bilder,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/a7v",
                  "notation": [
                    "3.2.1.9"
                  ],
                  "prefLabel": {
                    "de": "untersuchende und produktive Methoden kennen und anwenden: z.B. Texte vergleichen, weiterschreiben, Paralleltext verfassen, szenische Umsetzung,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/x2e",
                  "notation": [
                    "3.2.1.10"
                  ],
                  "prefLabel": {
                    "de": "eigene Deutungen des Textes entwickeln, mit anderen darüber sprechen und am Text belegen."
                  }
                }
              ]
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/z4p",
              "notation": [
                "3.2.2"
              ],
              "prefLabel": {
                "de": "Sach- und Gebrauchstexte verstehen und nutzen"
              },
              "narrower": [
                {
                  "id": "https://w3id.org/iqb/v30/k1/q4q",
                  "notation": [
                    "3.2.2.1"
                  ],
                  "prefLabel": {
                    "de": "verschiedene Textfunktionen und Textsorten unterscheiden: informieren (z.B. Lexikontext), appellieren (z.B. Werbetext), regulieren (z.B. Jugendschutzgesetz, Arbeitsvertrag), instruieren (z.B. Bedienungsanleitung),"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/p5t",
                  "notation": [
                    "3.2.2.2"
                  ],
                  "prefLabel": {
                    "de": "Informationen zielgerichtet entnehmen, ordnen, prüfen und ergänzen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/a7s",
                  "notation": [
                    "3.2.2.3"
                  ],
                  "prefLabel": {
                    "de": "nichtlineare Texte (auch im Zusammenhang mit linearen Texten) auswerten: z.B. Schaubilder,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/v2h",
                  "notation": [
                    "3.2.2.4"
                  ],
                  "prefLabel": {
                    "de": "Intention(en) eines Textes erkennen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/s3h",
                  "notation": [
                    "3.2.2.5"
                  ],
                  "prefLabel": {
                    "de": "aus Sach- und Gebrauchstexten begründete Schlussfolgerungen ziehen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/g7c",
                  "notation": [
                    "3.2.2.6"
                  ],
                  "prefLabel": {
                    "de": "Information und Wertung in Texten unterscheiden: z.B. in Zeitungen."
                  }
                }
              ]
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/r6g",
              "notation": [
                "3.2.3"
              ],
              "prefLabel": {
                "de": "Medien verstehen und nutzen"
              },
              "narrower": [
                {
                  "id": "https://w3id.org/iqb/v30/k1/x9g",
                  "notation": [
                    "3.2.3.1"
                  ],
                  "prefLabel": {
                    "de": "Informations- und Unterhaltungsfunktion unterscheiden: z.B. im Internet,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/q5y",
                  "notation": [
                    "3.2.3.2"
                  ],
                  "prefLabel": {
                    "de": "wesentliche Darstellungsmittel eines Mediums und deren Wirkungen kennen und einschätzen,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/t4a",
                  "notation": [
                    "3.2.3.3"
                  ],
                  "prefLabel": {
                    "de": "Intentionen und Wirkungen ausgewählter Medieninhalte erkennen und bewerten: z. B. Fernsehserie,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/a4v",
                  "notation": [
                    "3.2.3.4"
                  ],
                  "prefLabel": {
                    "de": "Lebenswirklichkeit von Realitätsdarstellungen und der Darstellung fiktionaler Welten in Medien unterscheiden,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/s4h",
                  "notation": [
                    "3.2.3.5"
                  ],
                  "prefLabel": {
                    "de": "Informationen zu einem Thema/Problem in unterschiedlichen Medien suchen, vergleichen, auswählen und bewerten,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/a7h",
                  "notation": [
                    "3.2.3.6"
                  ],
                  "prefLabel": {
                    "de": "Medien für die eigene Produktion kreativ nutzen."
                  }
                }
              ]
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v30/k1/d3y",
          "notation": [
            "3.3"
          ],
          "prefLabel": {
            "de": "Methoden und Arbeitstechniken"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/a2d",
              "notation": [
                "3.3.1"
              ],
              "prefLabel": {
                "de": "mit Nachschlagewerken umgehen können,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/s4v",
              "notation": [
                "3.3.2"
              ],
              "prefLabel": {
                "de": "recherchieren,"
