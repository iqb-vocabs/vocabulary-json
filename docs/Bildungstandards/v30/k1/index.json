      "prefLabel": {
        "de": "Sprache und Sprachgebrauch untersuchen"
      },
      "narrower": [
        {
          "id": "https://w3id.org/iqb/v30/k1/y5h",
          "notation": [
            "4.1"
          ],
          "prefLabel": {
            "de": "Äußerungen/Texte in Verwendungszusammenhängen reflektieren und bewusst gestalten"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/q4c",
              "notation": [
                "4.1.1"
              ],
              "prefLabel": {
                "de": "beim Sprachhandeln die Inhalts- und Beziehungsebene unterscheiden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/z7c",
              "notation": [
                "4.1.2"
              ],
              "prefLabel": {
                "de": "Bedingungen und Regeln für kommunikative Situationen im Alltag kennen,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/t7p",
              "notation": [
                "4.1.3"
              ],
              "prefLabel": {
                "de": "grundlegende Textfunktionen erfassen: Information (z.B. Zeitungsmeldung), Appell (z.B. Werbeanzeige), Kontakt (z.B. Bewerbung, Beschwerde); ästhetische Funktion (z.B. Gedicht),"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/g5s",
              "notation": [
                "4.1.4"
              ],
              "prefLabel": {
                "de": "„Sprachen in der Sprache“ kennen und in ihrer Funktion unterscheiden: Standardsprache, Umgangssprache; Dialekt; Gruppensprachen, Fachsprachen; gesprochene und geschriebene Sprache,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/u7d",
              "notation": [
                "4.1.5"
              ],
              "prefLabel": {
                "de": "Sprechweisen unterscheiden und ihre Wirkung einschätzen: z.B. abwertend, gehoben,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/y9b",
              "notation": [
                "4.1.6"
              ],
              "prefLabel": {
                "de": "ausgewählte Beispiele fremdsprachlicher Einflüsse kennen und bewerten,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/y9g",
              "notation": [
                "4.1.7"
              ],
              "prefLabel": {
                "de": "Unterschiede und Gemeinsamkeiten verschiedener Sprachen wahrnehmen."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v30/k1/x5c",
          "notation": [
            "4.2"
          ],
          "prefLabel": {
            "de": "Textbeschaffenheit analysieren und reflektieren"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/p6p",
              "notation": [
                "4.2.1"
              ],
              "prefLabel": {
                "de": "sprachliche Mittel zur Sicherung des Textzusammenhanges kennen und anwenden:"
              },
              "narrower": [
                {
                  "id": "https://w3id.org/iqb/v30/k1/s3g",
                  "notation": [
                    "4.2.1.1"
                  ],
                  "prefLabel": {
                    "de": "Wortebene (morphologische Mittel): Beziehungswörter (z.B. Konjunktion, Adverb, Pronomen),"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/g4r",
                  "notation": [
                    "4.2.1.2"
                  ],
                  "prefLabel": {
                    "de": "Satzebene (syntaktische Mittel): Satzarten; Satzreihe, Satzgefüge,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/z5d",
                  "notation": [
                    "4.2.1.3"
                  ],
                  "prefLabel": {
                    "de": "Bedeutungsebene (semantische Mittel): Synonyme; Schlüsselwörter; Oberbegriff/Unterbegriff,"
                  }
                }
              ]
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/d5e",
              "notation": [
                "4.2.2"
              ],
              "prefLabel": {
                "de": "Leistungen von Sätzen und Wortarten kennen und für Sprechen und Schreiben nutzen:"
              },
              "narrower": [
                {
                  "id": "https://w3id.org/iqb/v30/k1/p4s",
                  "notation": [
                    "4.2.2.1"
                  ],
                  "prefLabel": {
                    "de": "Satzstrukturen kennen und funktional verwenden: Hauptsatz, Nebensatz/Gliedsatz, Satzglied, Satzgliedteil,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/v3v",
                  "notation": [
                    "4.2.2.2"
                  ],
                  "prefLabel": {
                    "de": "Wortarten kennen und funktional gebrauchen: z.B. Verb: Zeitlichkeit; Substantiv/Nomen: Benennung; Adjektiv: Qualität,"
                  }
                },
                {
                  "id": "https://w3id.org/iqb/v30/k1/q4u",
                  "notation": [
                    "4.2.2.3"
                  ],
                  "prefLabel": {
                    "de": "grammatische Kategorien in situativen und funktionalen Zusammenhängen verwenden: z.B. Tempus, Aktiv/Passiv; Genus, Numerus, Kasus; Steigerung,"
                  }
                }
              ]
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/b4h",
              "notation": [
                "4.2.3"
              ],
              "prefLabel": {
                "de": "grundlegende Regeln der Orthografie und Zeichensetzung kennen und beim Sprachhandeln anwenden."
              }
            }
          ]
        },
        {
          "id": "https://w3id.org/iqb/v30/k1/f4q",
          "notation": [
            "4.3"
          ],
          "prefLabel": {
            "de": "Methoden und Arbeitstechniken"
          },
          "narrower": [
            {
              "id": "https://w3id.org/iqb/v30/k1/b9d",
              "notation": [
                "4.3.1"
              ],
              "prefLabel": {
                "de": "die Klang-, Weglass-, Umstell-, Ersatzprobe anwenden,"
              }
            },
            {
              "id": "https://w3id.org/iqb/v30/k1/p6y",
              "notation": [
                "4.3.2"
              ],
              "prefLabel": {
                "de": "Verfahren der Fehlerkontrolle: z.B. Nachschlagetechniken, gliederndes Mitsprechen."
              }
            }
          ]
        }
      ]
