{
  "id": "https://w3id.org/iqb/v71/cm2/",
  "type": "ConceptScheme",
  "title": {
    "de": "Kompetenzstufenmodelle - Chemie MSA - Erkenntnisgewinnung"
  },
  "description": {
    "de": "Kompetenzstufenmodelle zu den Bildungsstandards im Fach Chemie für den Mittleren Schulabschluss\n\nKompetenzbereiche „Erkenntnisgewinnung“"
  },
  "license": {
    "id": "https://creativecommons.org/publicdomain/zero/1.0/deed.de"
  },
  "hasTopConcept": [
    {
      "id": "https://w3id.org/iqb/v71/cm2/e9g",
      "prefLabel": {
        "de": "Kompetenzstufe I"
      },
      "definition": {
        "de": "Erkennen überprüfbarer Fragestellungen und Kennen einfacher Versuchsanordnungen und Modelle"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/cm2/f3d",
      "prefLabel": {
        "de": "Kompetenzstufe II"
      },
      "definition": {
        "de": "Nutzen einfacher Modelle, Anwenden einzelner Schritte der naturwissenschaftlichen Erkenntnisgewinnung"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/cm2/q7e",
      "prefLabel": {
        "de": "Kompetenzstufe III"
      },
      "definition": {
        "de": "Anwenden von naturwissenschaftlichen Methoden der Erkenntnisgewinnung und Modellen in einfachen fachlichen Zusammenhängen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/cm2/s4e",
      "prefLabel": {
        "de": "Kompetenzstufe IV"
      },
      "definition": {
        "de": "Begründetes Auswählen und Nutzen von naturwissenschaftlichen Methoden der Erkenntnisgewinnung (Experimente und Modelle) in komplexen Zusammenhängen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/cm2/y3r",
      "prefLabel": {
        "de": "Kompetenzstufe V"
      },
      "definition": {
        "de": "Berücksichtigung von Möglichkeiten und Grenzen von Experimenten und Modellen"
      }
    }
  ],
