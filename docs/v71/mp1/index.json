{
  "id": "https://w3id.org/iqb/v71/mp1/",
  "type": "ConceptScheme",
  "title": {
    "de": "Kompetenzstufenmodelle - Mathematik Primar"
  },
  "description": {
    "de": "Kompetenzstufenmodell zu den Bildungsstandards im Fach Mathematik für den Primarbereich (Jahrgangsstufe 4)"
  },
  "license": {
    "id": "https://creativecommons.org/publicdomain/zero/1.0/deed.de"
  },
  "hasTopConcept": [
    {
      "id": "https://w3id.org/iqb/v71/mp1/a9d",
      "prefLabel": {
        "de": "Stufe I"
      },
      "definition": {
        "de": "technische Grundlagen (Routineprozeduren auf Grundlage einfachen begrifflichen Wissens)"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/mp1/e3y",
      "prefLabel": {
        "de": "Stufe II"
      },
      "definition": {
        "de": "einfache Anwendungen von Grundlagenwissen (Routineprozeduren in einem klar strukturierten Kontext)"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/mp1/a5v",
      "prefLabel": {
        "de": "Stufe III"
      },
      "definition": {
        "de": "Erkennen und Nutzen von Zusammenhängen in einem vertrauten (mathematischen und sachbezogenen) Kontext"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/mp1/c2q",
      "prefLabel": {
        "de": "Stufe IV"
      },
      "definition": {
        "de": "sicheres und flexibles Anwenden von begrifflichem Wissen und Prozeduren im curricularen Umfang"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/mp1/p2p",
      "prefLabel": {
        "de": "Stufe V"
      },
      "definition": {
        "de": "Modellierung komplexer Probleme unter selbstständiger Entwicklung geeigneter Strategien"
      }
    }
  ],
