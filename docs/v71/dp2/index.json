{
  "id": "https://w3id.org/iqb/v71/dp2/",
  "type": "ConceptScheme",
  "title": {
    "de": "Kompetenzstufenmodelle - Deutsch Primar - Lesen"
  },
  "description": {
    "de": "Kompetenzstufenmodell zu den Bildungsstandards für das Fach Deutsch im Kompetenzbereich „Lesen – mit Texten und Medien umgehen“ – Primarbereich –"
  },
  "license": {
    "id": "https://creativecommons.org/publicdomain/zero/1.0/deed.de"
  },
  "hasTopConcept": [
    {
      "id": "https://w3id.org/iqb/v71/dp2/r7f",
      "prefLabel": {
        "de": "Kompetenzstufe I"
      },
      "definition": {
        "de": "explizit angegebene Einzelinformationen identifizieren"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/dp2/q6e",
      "prefLabel": {
        "de": "Kompetenzstufe II"
      },
      "definition": {
        "de": "benachbarte Informationen miteinander verknüpfen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/dp2/r2x",
      "prefLabel": {
        "de": "Kompetenzstufe III"
      },
      "definition": {
        "de": "verstreute Informationen miteinander verknüpfen und den Text ansatzweise als ganzen erfassen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/dp2/t5h",
      "prefLabel": {
        "de": "Kompetenzstufe IV"
      },
      "definition": {
        "de": "für die Herstellung von Kohärenz auf der Ebene des Textes wesentliche Aspekte erfassen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/dp2/f9v",
      "prefLabel": {
        "de": "Kompetenzstufe V"
      },
      "definition": {
        "de": "auf zentrale Aspekte des Textes bezogene Aussagen selbstständig begründen"
      }
    }
  ],
