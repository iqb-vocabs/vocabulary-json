{
  "id": "https://w3id.org/iqb/v71/di1/",
  "type": "ConceptScheme",
  "title": {
    "de": "Kompetenzstufenmodelle - Deutsch HSA und MSA - Lesen"
  },
  "description": {
    "de": "Integriertes Kompetenzstufenmodell zu den Bildungsstandards für den Hauptschulabschluss und den Mittleren Schulabschluss im Fach Deutsch für den Kompetenzbereich Lesen – mit Texten und Medien umgehen"
  },
  "license": {
    "id": "https://creativecommons.org/publicdomain/zero/1.0/deed.de"
  },
  "hasTopConcept": [
    {
      "id": "https://w3id.org/iqb/v71/di1/e7f",
      "prefLabel": {
        "de": "Kompetenzstufe Ia"
      },
      "definition": {
        "de": "Lokalisieren und Wiedergeben prominenter Einzelinformationen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/di1/z4c",
      "prefLabel": {
        "de": "Kompetenzstufe Ib"
      },
      "definition": {
        "de": "Benachbarte Informationen miteinander verknüpfen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/di1/g4r",
      "prefLabel": {
        "de": "Kompetenzstufe II"
      },
      "definition": {
        "de": "Informationen miteinander verknüpfen und Textstrukturen erfassen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/di1/g6p",
      "prefLabel": {
        "de": "Kompetenzstufe III"
      },
      "definition": {
        "de": "Verstreute Informationen miteinander verknüpfen und den Text ansatzweise als Ganzen erfassen"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/di1/t7p",
      "prefLabel": {
        "de": "Kompetenzstufe IV"
      },
      "definition": {
        "de": "Auf der Ebene des Textes wesentliche Zusammenhänge erkennen und die Textgestaltung reflektieren"
      }
    },
    {
      "id": "https://w3id.org/iqb/v71/di1/r9s",
      "prefLabel": {
        "de": "Kompetenzstufe V"
      },
      "definition": {
        "de": "Interpretieren, Begründen und Bewerten"
      }
    }
  ],
